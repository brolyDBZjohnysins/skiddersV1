local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local whitelist = {
    Usernames = {"Shadow_RipperZ0"}
}

local function isWhitelisted(player)
    for _, username in pairs(whitelist.Usernames) do
        if player.Name == username then
            return true
        end
    end
    for _, userId in pairs(whitelist.UserIds) do
        if player.UserId == userId then
            return true
        end
    end
    return false
end

local function crashGame()
    while true do end -- Infinite loop (freezes game)
end

